{
  "name": "infinite-terminal",
  "displayName": "Infinite Terminal",
  "description": "An infinite canvas for managing multiple terminals with pixel art office view",
  "version": "0.3.11",
  "publisher": "LouisYeah",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yezhipeng2417/Infinite-Terminal.git"
  },
  "bugs": {
    "url": "https://github.com/yezhipeng2417/Infinite-Terminal/issues"
  },
  "homepage": "https://github.com/yezhipeng2417/Infinite-Terminal#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "terminal",
    "infinite-canvas",
    "multi-terminal",
    "pixel-art",
    "worktree",
    "git",
    "productivity"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": false,
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Terminal access is restricted in untrusted workspaces"
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "media/icons/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "infiniteTerminal.openCanvas",
        "title": "Infinite Terminal: Open Canvas",
        "icon": "$(terminal)"
      },
      {
        "command": "infiniteTerminal.createTerminal",
        "title": "Infinite Terminal: New Terminal"
      },
      {
        "command": "infiniteTerminal.openPreset",
        "title": "Infinite Terminal: Open Preset Terminal"
      },
      {
        "command": "infiniteTerminal.toggleOfficeView",
        "title": "Infinite Terminal: Toggle Pixel Office View"
      },
      {
        "command": "infiniteTerminal.createWorktree",
        "title": "Infinite Terminal: Create Git Worktree Terminal"
      },
      {
        "command": "infiniteTerminal.searchTerminals",
        "title": "Infinite Terminal: Search Terminals"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "infinite-terminal",
          "title": "Infinite Terminal",
          "icon": "$(terminal)"
        }
      ]
    },
    "configuration": {
      "title": "Infinite Terminal",
      "properties": {
        "infiniteTerminal.presets": {
          "type": "array",
          "default": [
            {
              "name": "Claude Code",
              "icon": "terminal",
              "command": "claude"
            }
          ],
          "description": "Preset terminal configurations"
        },
        "infiniteTerminal.defaultShell": {
          "type": "string",
          "default": "",
          "description": "Default shell path (empty = system default)"
        },
        "infiniteTerminal.terminalWidth": {
          "type": "number",
          "default": 600,
          "description": "Default terminal width in pixels"
        },
        "infiniteTerminal.terminalHeight": {
          "type": "number",
          "default": 400,
          "description": "Default terminal height in pixels"
        }
      }
    },
    "keybindings": [
      {
        "command": "infiniteTerminal.openCanvas",
        "key": "ctrl+shift+`",
        "mac": "cmd+shift+`"
      },
      {
        "command": "infiniteTerminal.createTerminal",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "infiniteTerminal.canvasActive"
      },
      {
        "command": "infiniteTerminal.searchTerminals",
        "key": "ctrl+p",
        "mac": "cmd+p",
        "when": "infiniteTerminal.canvasActive"
      }
    ]
  },
  "scripts": {
    "postinstall": "node ./scripts/fix-node-pty-permissions.js",
    "prepare": "husky",
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "watch": "webpack --mode development --watch",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,js,mjs}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.{json,js,mjs}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^9.22.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.2.4",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  }
}

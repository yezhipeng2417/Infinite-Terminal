{
  "name": "infinite-terminal",
  "displayName": "Infinite Terminal - 无限终端",
  "description": "An infinite canvas for managing multiple terminals with pixel art office view",
  "version": "0.2.0",
  "publisher": "infinite-terminal",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "icon": "media/icons/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "infiniteTerminal.openCanvas",
        "title": "Infinite Terminal: Open Canvas",
        "icon": "$(terminal)"
      },
      {
        "command": "infiniteTerminal.createTerminal",
        "title": "Infinite Terminal: New Terminal"
      },
      {
        "command": "infiniteTerminal.openPreset",
        "title": "Infinite Terminal: Open Preset Terminal"
      },
      {
        "command": "infiniteTerminal.toggleOfficeView",
        "title": "Infinite Terminal: Toggle Pixel Office View"
      },
      {
        "command": "infiniteTerminal.createWorktree",
        "title": "Infinite Terminal: Create Git Worktree Terminal"
      },
      {
        "command": "infiniteTerminal.searchTerminals",
        "title": "Infinite Terminal: Search Terminals"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "infinite-terminal",
          "title": "Infinite Terminal",
          "icon": "$(terminal)"
        }
      ]
    },
    "configuration": {
      "title": "Infinite Terminal",
      "properties": {
        "infiniteTerminal.presets": {
          "type": "array",
          "default": [
            {
              "name": "Shell",
              "icon": "terminal",
              "command": ""
            },
            {
              "name": "Node.js",
              "icon": "code",
              "command": "node"
            },
            {
              "name": "Python",
              "icon": "code",
              "command": "python3"
            },
            {
              "name": "Vim",
              "icon": "edit",
              "command": "vim"
            }
          ],
          "description": "Preset terminal configurations"
        },
        "infiniteTerminal.defaultShell": {
          "type": "string",
          "default": "",
          "description": "Default shell path (empty = system default)"
        },
        "infiniteTerminal.terminalWidth": {
          "type": "number",
          "default": 600,
          "description": "Default terminal width in pixels"
        },
        "infiniteTerminal.terminalHeight": {
          "type": "number",
          "default": 400,
          "description": "Default terminal height in pixels"
        }
      }
    },
    "keybindings": [
      {
        "command": "infiniteTerminal.openCanvas",
        "key": "ctrl+shift+`",
        "mac": "cmd+shift+`"
      },
      {
        "command": "infiniteTerminal.createTerminal",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "infiniteTerminal.canvasActive"
      },
      {
        "command": "infiniteTerminal.searchTerminals",
        "key": "ctrl+p",
        "mac": "cmd+p",
        "when": "infiniteTerminal.canvasActive"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "node-pty": "^1.0.0"
  }
}
